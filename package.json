    "@google-cloud/translate": "^8.5.0",
    "@google/generative-ai": "^0.21.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "helmet": "^8.0.0"
  }
